# ===== Required =====
FIREBASE_PROJECT_ID=your-project-id
# เลือกอย่างใดอย่างหนึ่ง
FIREBASE_SERVICE_ACCOUNT_BASE64=base64-of-service-account-json
# หรือใช้ 3 ตัวนี้แทน
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ใช้เซ็น session cookie/JWT กำหนดเป็น random ยาว ๆ
SESSION_SECRET=change-this-long-random-secret

# ใช้สร้าง Super Admin ครั้งแรกผ่าน /api/admin/bootstrap หรือ npm run seed:admin
SETUP_SECRET=change-this-setup-secret
DEFAULT_ADMIN_CODE=ADMIN
DEFAULT_ADMIN_PIN=123456

# ===== Optional defaults =====
NEXT_PUBLIC_APP_NAME=NAK Incentive
MAX_TRUSTED_DEVICES=2
MAX_FAILED_PIN=5
SESSION_DAYS=7
PIN_LENGTH=6
ALLOW_STAFF_EXPORT=false
ALLOW_MANAGER_EXPORT=true
